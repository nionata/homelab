{
  "name": "homelab-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "mounts": [
    // Isolated volumes cache build system artifacts and provide native, high-performance file I/O
    "source=nix-store,target=/nix,type=volume",
    "source=nix-cache,target=/root/.cache/nix,type=volume",
    "source=claude-state,target=/root/.config/claude,type=volume",
    "source=cargo-home,target=/var/cache/cargo/home,type=volume",
    "source=cargo-target-${localWorkspaceFolderBasename},target=/var/cache/cargo/target,type=volume",
    // TODO(https://github.com/nionata/dotfiles/issues/8): Save direnv allow layout state
    // Mount the entire developer directory so we can access all the projects from the dev environment
    "source=${localEnv:HOME}/Developer,target=/root/Developer,type=bind",
    // Share dotfiles with host for seamless integration of the guest container with the host
    // TODO(https://github.com/nionata/dotfiles/issues/9): Build these into the docker image
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.zshenv,target=/root/.zshenv,type=bind,readonly",
    "source=${localEnv:HOME}/.zshrc,target=/root/.zshrc,type=bind,readonly",
    "source=${localEnv:HOME}/.config/gh,target=/root/.config/gh,type=bind,readonly",
    // Share history with the host, this seems to only work with OrbStack.
    // DockerDesktop has corruption issues quite reliably.
    "source=${localEnv:HOME}/.zsh_history,target=/root/.zsh_history,type=bind"
  ],
  "containerEnv": {
    "CARGO_TARGET_DIR": "/var/cache/cargo/target",
    "CARGO_HOME": "/var/cache/cargo/home"
  },
  // Use the image's infinite command.
  "overrideCommand": false,
  "customizations": {
    "vscode": {
      "extensions": [
        "mkhl.direnv",
        "rust-lang.rust-analyzer"
      ],
      "settings": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "rust-analyzer.server.path": "rust-analyzer"
      },
    }
  }
}